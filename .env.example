# Optional overrides — every field on the Settings model is reachable through
# WIKIREC_<NESTED>__<FIELD> using a double-underscore for nesting.

# Spider
# WIKIREC_SPIDER__START_URL=https://en.wikipedia.org/wiki/Madagascar
# WIKIREC_SPIDER__MAX_PAGES=5000
# WIKIREC_SPIDER__MAX_LINKS_PER_PAGE=10
# WIKIREC_SPIDER__CONCURRENT_REQUESTS=32
# WIKIREC_SPIDER__DOWNLOAD_DELAY=0.1
# WIKIREC_SPIDER__SEED=

# Engine
# WIKIREC_ENGINE__TEXT_COLUMN=lemmas
# WIKIREC_ENGINE__NGRAM_MAX=2
# WIKIREC_ENGINE__MIN_DF=15
# WIKIREC_ENGINE__MAX_DF=0.60
# WIKIREC_ENGINE__SUBLINEAR_TF=true

# Strategy
# WIKIREC_STRATEGY__NUM_ARTICLES=10
# WIKIREC_STRATEGY__NUM_TRIALS=1
# WIKIREC_STRATEGY__RUN_EXPLAINABILITY=true

# Paths (relative to repo root or absolute)
# WIKIREC_PATHS__DATA_DIR=data
# WIKIREC_PATHS__PLOTS_DIR=plots
